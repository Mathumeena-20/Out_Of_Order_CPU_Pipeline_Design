# =====================================================
# Clock Definitions
# =====================================================

# -----------------------------------------------------
# Core Clock
# -----------------------------------------------------

create_clock \
-name core_clk \
-period 10.0 \
[get_ports clk]

# -----------------------------------------------------
# Generated Clocks
# -----------------------------------------------------

derive_pll_clocks

derive_clock_uncertainty

# -----------------------------------------------------
# Clock Groups
# -----------------------------------------------------

set_clock_groups \
-asynchronous \
-group [get_clocks core_clk]
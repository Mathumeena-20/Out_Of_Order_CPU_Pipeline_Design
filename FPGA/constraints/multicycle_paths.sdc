# =====================================================
# Multi-Cycle Paths
# =====================================================

# -----------------------------------------------------
# Multiplier Pipeline
# -----------------------------------------------------

set_multicycle_path 2 \
-from [get_registers mul_*] \
-to [get_registers mul_*]

# -----------------------------------------------------
# Divider Pipeline
# -----------------------------------------------------

set_multicycle_path 4 \
-from [get_registers div_*] \
-to [get_registers div_*]